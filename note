#create 
#  * 方法1：venv（Python自带）
cd 项目文件夹
python -m venv venv
venv\Scripts\activate  # Windows
source venv/bin/activate  # Mac/Linux

# 方法2：conda
conda create -n 项目名 python=3.11
conda activate 项目名

#about powershell(for windows) and bash(for linux and mac)
本质差异：
Bash:管道里是“字”
PowerShell:管道里是“结构化对象”

